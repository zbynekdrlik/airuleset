+def test_wiring_is_after_helper_definitions():
+    """Regression for the live NameError: the module body runs top-to-bottom, so
+    the #696 SALESPERSON WIRING block (which CALLS _rep_users_from_display /
+    _web_user_id / build_user_canon_map at module level) MUST appear AFTER all three
+    helpers are defined. The isolated resolver-region exec in the other tests can't
+    catch a module-level ordering bug — this asserts source order directly, for BOTH
+    importers."""
+    for rt in (RUNTIME, HERE.parent.parent / "quotes" / "importer_runtime.py"):
+        src = rt.read_text(encoding="utf-8")
+        call_pos = src.index("REP_USERS = _rep_users_from_display")
+        for helper in ("_rep_users_from_display", "_web_user_id", "build_user_canon_map"):
+            def_pos = src.index(f"def {helper}(")
+            assert def_pos < call_pos, (
+                f"{rt.name}: '{helper}' is DEFINED at {def_pos} but first CALLED at "
+                f"{call_pos} (module-level NameError at runtime). The #696 SALESPERSON "
+                f"WIRING block must come after all resolver-helper definitions."
+            )
+
