{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/session-start-fetch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-sensitive-staging.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-push-lint.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-push-test-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-custom-monitor.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-ask-auto-answer.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "CronCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-cron-ci-monitor.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/post-push-ci-cleanup.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-ci.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-prose-violations.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/notify-discord.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
