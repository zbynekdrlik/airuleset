{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/session-start-fetch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-sensitive-staging.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-gh-invalid-json-flag.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-push-lint.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-push-test-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-deploy-clean-tree.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-push-base-sync.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-tier0-local-build.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-ask-auto-answer.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/pre-agent-validate-subagent-type.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/post-push-ci-cleanup.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-ci.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-prose-violations.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-untracked-work.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-status-marker.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-playbook-review.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-prod-gating.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/stop-check-sendmessage-narration.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/notify-discord-pending.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/notify-api-error.sh",
            "timeout": 8
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/notify-discord.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/clear-question-dedup.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
