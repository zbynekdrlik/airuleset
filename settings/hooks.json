{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/session-start-fetch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/devel/airuleset/hooks/block-sensitive-staging.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
